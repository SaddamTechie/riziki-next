# ─────────────────────────────────────────────────────────────────────────────
# Riziki — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── Database (Neon PostgreSQL) ───────────────────────────────────────────────
# Get from: https://neon.tech → New Project → Connection String
DATABASE_URL=postgresql://neondb_owner:url

# ─── Authentication (Better Auth) ────────────────────────────────────────────
# Generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-32-plus-character-secret-here
BETTER_AUTH_URL=http://localhost:3000

# ─── Storage (Cloudinary) ────────────────────────────────────────────────────
# Get from: https://cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=cloudinary_name
CLOUDINARY_API_KEY=cloudinary_key
CLOUDINARY_API_SECRET=cloudinary_secret
# Also expose cloud name to the client for the image loader
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=cloudinary_name

# ─── WhatsApp ────────────────────────────────────────────────────────────────
# Store owner's WhatsApp number in international format (no + or spaces)
# e.g. 254712345678 for a Kenyan number
NEXT_PUBLIC_WHATSAPP_NUMBER=254797654324

# ─── Google Analytics ─────────────────────────────────────────────────────────
# Get from: https://analytics.google.com → Admin → Data Streams → Measurement ID
# Only loaded in production. Leave empty to disable entirely.
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── API Security (X-App-Token) ───────────────────────────────────────────────
# The Expo admin app must send this as the X-App-Token header on every request.
# Leave empty (or unset) in development to skip the check entirely.
# Generate with: openssl rand -hex 32
APP_SECRET=app_secret

# ─── Bootstrap defaults ───────────────────────────────────────────────────────
# Initial site values used before the shop owner configures anything via the
# Expo admin app. Once a DB row exists, the DB value always wins over these.
# Safe on redeployments — the database is never touched by redeploying.
INITIAL_SITE_NAME=Riziki
INITIAL_SITE_TAGLINE=Fashion That Moves With You
INITIAL_SEO_DESCRIPTION=Shop the latest fashion trends at Riziki.
INITIAL_CONTACT_EMAIL=support@domain.com

# ─── Payment (fill in when integrating a provider) ───────────────────────────
# Daraja / M-Pesa (Safaricom)
# PAYMENT_CONSUMER_KEY=
# PAYMENT_CONSUMER_SECRET=
# PAYMENT_SHORTCODE=
# PAYMENT_PASSKEY=
# PAYMENT_CALLBACK_URL=https://yoursite.com/api/payments/webhook

